{
  "name": "AshWatch",
  "short_name": "AshWatch",
  "description": "A private K-drama diary for watchlists, ratings, posters, and AI recommendations.",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "display_override": ["fullscreen", "standalone", "minimal-ui"],
  "orientation": "portrait",
  "background_color": "#071827",
  "theme_color": "#071827",
  "icons": [
    {
      "src": "/icons/ashwatch-icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/ashwatch-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any"
    },
    {
      "src": "/icons/ashwatch-icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "maskable"
    }
  ]
}
